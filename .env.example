## Core APIs
YOUTUBE_API_KEY=your_youtube_api_key

## Image + Video + TTS — all Gemini (https://ai.google.dev/gemini-api/docs)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

## Legacy TTS (kept for fallback)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

## LLM — Claude Max Plan via Claude Code CLI (no API billing), Ollama for utilities
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=qwen3:30b

## LLM routing strategy
#   hybrid            — research/script/fact-check via `claude -p`, parse/image-prompt via Ollama (default)
#   claude-code-only  — everything via `claude -p` headless
#   local-only        — everything via Ollama (offline dev)
LLM_STRATEGY=hybrid

## Image pipeline
IMAGE_CONCURRENCY=6

## Veo video clip generation — set to 1 to skip the Veo step entirely (fastest pipeline)
SKIP_VEO=0

## Fact-check depth
##   full  — citation reality + claim accuracy + replication awareness + tone (5–15 min). Default for uploads.
##   quick — citation existence + structure only (2–4 min). Good for drafts.
FACT_CHECK_MODE=full

## YouTube upload — OAuth 2.0 client from Google Cloud Console
## (APIs & Services → Credentials → OAuth 2.0 Client ID → "Web application")
## Authorized redirect URI must include: http://localhost:3000/api/youtube/oauth/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
# Optional override if running the dashboard on a different port/host:
YOUTUBE_OAUTH_REDIRECT=http://localhost:3000/api/youtube/oauth/callback

## Optional: default theme for nightly scheduled runs (see docs/scheduling.md)
NIGHTLY_THEME=
DASHBOARD_URL=http://localhost:3000
